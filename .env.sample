# ---- Slack (Socket Mode: no public URL needed) ----
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token   # needs connections:write

# ---- Model ----
ANTHROPIC_API_KEY=sk-ant-your-key

# ---- GitHub: choose ONE of the two blocks ----

# (recommended) GitHub App scoped to your four repos
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
# Paste the full PEM. If your secret store is single-line, escape newlines as \n —
# the app un-escapes them automatically.

# (quickstart) OR a fine-grained PAT scoped to the four repos
# Issues: Read+Write, Contents: Read, Metadata: Read
GITHUB_TOKEN=
